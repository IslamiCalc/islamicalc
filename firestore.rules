rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // users/{uid}
    // ============================================================
    match /users/{uid} {
      // يقرأ: المستخدم نفسه فقط
      allow read: if request.auth != null && request.auth.uid == uid;

      // يكتب: المستخدم نفسه — مع التحقق من أنواع البيانات
      allow write: if request.auth != null
        && request.auth.uid == uid
        && validUserData(request.resource.data);

      // يحدّث: المستخدم نفسه فقط — لا يقدر يغيّر uid/email
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
    }

    // ============================================================
    // Leaderboard — قراءة عامة (فقط حقول محدودة)
    // ============================================================
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if false; // يكتب فقط عبر Cloud Function
    }

    // ============================================================
    // أي مسار آخر — محجوب
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ============================================================
    // دالة التحقق
    // ============================================================
    function validUserData(data) {
      return data.xp is number
        && data.xp >= 0
        && data.xp <= 999999
        && data.level is number
        && data.level >= 1
        && data.level <= 9
        && data.streak is number
        && data.streak >= 0
        && data.name is string
        && data.name.size() <= 100;
    }
  }
}
