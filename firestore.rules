rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // users/{uid}
    // ============================================================
    match /users/{uid} {

      // ✅ القراءة: المستخدم نفسه فقط
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // ✅ الإنشاء: المستخدم نفسه مع التحقق الكامل من البيانات
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUserData(request.resource.data);

      // ✅ التحديث:
      //    - المستخدم نفسه فقط
      //    - uid و email لا يتغيران أبداً
      //    - البيانات تمر بالتحقق
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.uid   == resource.data.uid
                    && request.resource.data.email == resource.data.email
                    && validUserData(request.resource.data);

      // ✅ الحذف: ممنوع نهائياً من الـ client
      //    (الحذف يتم فقط عبر Cloud Functions أو Console)
      allow delete: if false;

      // ============================================================
      // users/{uid}/khatmas/{khatmaId} — ختمات المستخدم
      // ============================================================
      match /khatmas/{khatmaId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      // ============================================================
      // users/{uid}/activity/{docId} — سجل النشاط
      // ============================================================
      match /activity/{docId} {
        allow read:   if request.auth != null
                      && request.auth.uid == uid;
        // الكتابة فقط للإضافة — لا حذف ولا تعديل
        allow create: if request.auth != null
                      && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // ============================================================
    // leaderboard — قراءة عامة للمسجّلين، كتابة عبر Cloud Functions
    // ============================================================
    match /leaderboard/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ============================================================
    // arenaQuestions — قراءة فقط لجميع المستخدمين المسجّلين
    // ============================================================
    match /arenaQuestions/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ============================================================
    // arenaAnswers/{uid} — إجابات الميدان — المستخدم يكتب لنفسه فقط
    // ============================================================
    match /arenaAnswers/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ============================================================
    // أي مسار آخر غير معرّف — محجوب افتراضياً
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ============================================================
    // دالة التحقق من بيانات المستخدم
    // ============================================================
    function validUserData(data) {
      return
        // XP: عدد صحيح موجب — حد 100,000
        data.xp is number
        && data.xp >= 0
        && data.xp <= 100000

        // المستوى: 1 إلى 20
        && data.level is number
        && data.level >= 1
        && data.level <= 20

        // الـ streak: 0 إلى 3650 يوم
        && data.streak is number
        && data.streak >= 0
        && data.streak <= 3650

        // الاسم: نص لا يتجاوز 40 حرفاً
        && data.name is string
        && data.name.size() <= 40

        // الشارات: قائمة لا تتجاوز 100 عنصر
        && data.badges is list
        && data.badges.size() <= 100;
    }
  }
}
