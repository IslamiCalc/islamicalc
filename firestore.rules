rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function validOptionalString(value, limit) {
      return value == null || (value is string && value.size() <= limit);
    }

    function validOptionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function validNonNegativeNumber(value, limit) {
      return value is number && value >= 0 && value <= limit;
    }

    function validDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validWeekKey(value) {
      return value is string && value.matches('^\\d{4}-W\\d{2}$');
    }

    function validKhatmaStats(value) {
      return value is map
        && value.keys().hasOnly(['completed', 'currentPage', 'currentJuz', 'streak', 'lastRead'])
        && validNonNegativeNumber(value.completed, 604)
        && validNonNegativeNumber(value.currentPage, 604)
        && validNonNegativeNumber(value.currentJuz, 30)
        && validNonNegativeNumber(value.streak, 3650)
        && validOptionalString(value.lastRead, 40);
    }

    function validAthkarStats(value) {
      return value is map
        && value.keys().hasOnly(['totalDone', 'totalTasbih'])
        && validNonNegativeNumber(value.totalDone, 1000000)
        && validNonNegativeNumber(value.totalTasbih, 1000000);
    }

    function validArenaStats(value) {
      return value is map
        && value.keys().hasOnly(['wins', 'totalGames', 'correctAnswers', 'wrongAnswers', 'bestStreak', 'perfectGames'])
        && validNonNegativeNumber(value.wins, 100000)
        && validNonNegativeNumber(value.totalGames, 100000)
        && validNonNegativeNumber(value.correctAnswers, 1000000)
        && validNonNegativeNumber(value.wrongAnswers, 1000000)
        && validNonNegativeNumber(value.bestStreak, 100000)
        && validNonNegativeNumber(value.perfectGames, 100000);
    }

    function validKhatmaPages(value) {
      return value is map
        && value.keys().size() <= 604;
    }

    function validBadgeList(value) {
      return value is list
        && value.size() <= 32
        && value.hasOnly([
          'first_login',
          'arena_xp_100',
          'arena_xp_500',
          'arena_xp_1000',
          'arena_win_1',
          'arena_win_10',
          'arena_win_50',
          'arena_streak_5',
          'arena_streak_10',
          'arena_perfect',
          'khatma_complete',
          'zakat_calc'
        ]);
    }

    function validActivityList(value) {
      return value is list
        && value.size() <= 50;
    }

    function validArenaXPLog(value) {
      return value is map
        && value.keys().hasOnly([
          'arena_answer',
          'arena_correct',
          'arena_streak_5',
          'arena_streak_10',
          'arena_win',
          'arena_perfect',
          'age_calc',
          'login_bonus',
          'daily_visit'
        ])
        && (!('arena_answer' in value) || validNonNegativeNumber(value.arena_answer, 1000000))
        && (!('arena_correct' in value) || validNonNegativeNumber(value.arena_correct, 1000000))
        && (!('arena_streak_5' in value) || validNonNegativeNumber(value.arena_streak_5, 1000000))
        && (!('arena_streak_10' in value) || validNonNegativeNumber(value.arena_streak_10, 1000000))
        && (!('arena_win' in value) || validNonNegativeNumber(value.arena_win, 1000000))
        && (!('arena_perfect' in value) || validNonNegativeNumber(value.arena_perfect, 1000000))
        && (!('age_calc' in value) || validNonNegativeNumber(value.age_calc, 1000000))
        && (!('login_bonus' in value) || validNonNegativeNumber(value.login_bonus, 1000000))
        && (!('daily_visit' in value) || validNonNegativeNumber(value.daily_visit, 1000000));
    }

    function validUserData(data, uid) {
      return data.keys().hasOnly([
          'uid',
          'displayName',
          'email',
          'photoURL',
          'arenaXP',
          'streak',
          'lastVisit',
          'createdAt',
          'updatedAt',
          'khatmaStats',
          'khatmaPages',
          'athkarStats',
          'arenaStats',
          'zakatCalcs',
          'badges',
          'activity',
          'arenaXPLog'
        ])
        && data.keys().hasAll([
          'uid',
          'displayName',
          'email',
          'photoURL',
          'arenaXP',
          'streak',
          'lastVisit',
          'createdAt',
          'khatmaStats',
          'khatmaPages',
          'athkarStats',
          'arenaStats',
          'zakatCalcs',
          'badges',
          'activity',
          'arenaXPLog'
        ])
        && data.uid == uid
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 80
        && validOptionalString(data.email, 200)
        && validOptionalString(data.photoURL, 500)
        && validNonNegativeNumber(data.arenaXP, 1000000)
        && validNonNegativeNumber(data.streak, 3650)
        && validDateKey(data.lastVisit)
        && data.createdAt is timestamp
        && validOptionalTimestamp(data.updatedAt)
        && validKhatmaStats(data.khatmaStats)
        && validKhatmaPages(data.khatmaPages)
        && validAthkarStats(data.athkarStats)
        && validArenaStats(data.arenaStats)
        && validNonNegativeNumber(data.zakatCalcs, 1000000)
        && validBadgeList(data.badges)
        && validActivityList(data.activity)
        && validArenaXPLog(data.arenaXPLog);
    }

    function validStoredEmail(nextEmail, currentEmail) {
      return nextEmail == currentEmail
        || (request.auth.token.email != null && nextEmail == request.auth.token.email)
        || (currentEmail == null && nextEmail == null);
    }

    function preservesCreatedAt(nextValue, currentValue) {
      return currentValue == null || nextValue == currentValue;
    }

    function validLeaderboardData(data, uid) {
      return data.keys().hasOnly([
          'uid',
          'displayName',
          'photoURL',
          'level',
          'levelIcon',
          'arenaXP',
          'dailyXP',
          'weeklyXP',
          'rankScore',
          'dailyScore',
          'weeklyScore',
          'wins',
          'totalGames',
          'correctAnswers',
          'bestStreak',
          'perfectGames',
          'updatedAtMs',
          'createdAtMs',
          'dailyKey',
          'weeklyKey',
          'updatedAt'
        ])
        && data.keys().hasAll([
          'uid',
          'displayName',
          'photoURL',
          'level',
          'levelIcon',
          'arenaXP',
          'dailyXP',
          'weeklyXP',
          'rankScore',
          'dailyScore',
          'weeklyScore',
          'wins',
          'totalGames',
          'correctAnswers',
          'bestStreak',
          'perfectGames',
          'updatedAtMs',
          'createdAtMs',
          'dailyKey',
          'weeklyKey',
          'updatedAt'
        ])
        && data.uid == uid
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 80
        && validOptionalString(data.photoURL, 500)
        && data.level is string
        && data.level.size() <= 40
        && validOptionalString(data.levelIcon, 8)
        && validNonNegativeNumber(data.arenaXP, 1000000)
        && validNonNegativeNumber(data.dailyXP, 1000000)
        && validNonNegativeNumber(data.weeklyXP, 1000000)
        && validNonNegativeNumber(data.rankScore, 9999999999999)
        && validNonNegativeNumber(data.dailyScore, 9999999999999)
        && validNonNegativeNumber(data.weeklyScore, 9999999999999)
        && validNonNegativeNumber(data.wins, 100000)
        && validNonNegativeNumber(data.totalGames, 100000)
        && validNonNegativeNumber(data.correctAnswers, 1000000)
        && validNonNegativeNumber(data.bestStreak, 100000)
        && validNonNegativeNumber(data.perfectGames, 100000)
        && validNonNegativeNumber(data.updatedAtMs, 9999999999999)
        && validNonNegativeNumber(data.createdAtMs, 9999999999999)
        && validDateKey(data.dailyKey)
        && validWeekKey(data.weeklyKey)
        && data.updatedAt is timestamp;
    }

    function validKhatmaRoomData(data, roomId) {
      return data.keys().hasOnly([
          'name',
          'ownerUid',
          'ownerName',
          'inviteCode',
          'memberCount',
          'totalCompletedPages',
          'progressPercent',
          'createdAt',
          'updatedAt',
          'lastActivityAtMs'
        ])
        && data.keys().hasAll([
          'name',
          'ownerUid',
          'ownerName',
          'inviteCode',
          'memberCount',
          'totalCompletedPages',
          'progressPercent',
          'createdAt',
          'updatedAt',
          'lastActivityAtMs'
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 80
        && data.ownerUid is string
        && data.ownerUid.size() > 0
        && data.ownerUid.size() <= 128
        && data.ownerName is string
        && data.ownerName.size() > 0
        && data.ownerName.size() <= 80
        && data.inviteCode == roomId
        && validNonNegativeNumber(data.memberCount, 200)
        && validNonNegativeNumber(data.totalCompletedPages, 120800)
        && validNonNegativeNumber(data.progressPercent, 100)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && validNonNegativeNumber(data.lastActivityAtMs, 9999999999999);
    }

    function validKhatmaRoomMemberData(data, uid) {
      return data.keys().hasOnly([
          'uid',
          'displayName',
          'photoURL',
          'currentPage',
          'completedPages',
          'completedSurahs',
          'streak',
          'joinedAt',
          'updatedAt',
          'lastActivityAtMs'
        ])
        && data.keys().hasAll([
          'uid',
          'displayName',
          'photoURL',
          'currentPage',
          'completedPages',
          'completedSurahs',
          'streak',
          'joinedAt',
          'updatedAt',
          'lastActivityAtMs'
        ])
        && data.uid == uid
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 80
        && validOptionalString(data.photoURL, 500)
        && validNonNegativeNumber(data.currentPage, 604)
        && validNonNegativeNumber(data.completedPages, 604)
        && validNonNegativeNumber(data.completedSurahs, 114)
        && validNonNegativeNumber(data.streak, 3650)
        && data.joinedAt is timestamp
        && data.updatedAt is timestamp
        && validNonNegativeNumber(data.lastActivityAtMs, 9999999999999);
    }
    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
                    && validUserData(request.resource.data, uid);

      allow update: if isOwner(uid)
                    && request.resource.data.uid == resource.data.uid
                    && validStoredEmail(request.resource.data.email, resource.data.email)
                    && preservesCreatedAt(request.resource.data.createdAt, resource.data.createdAt)
                    && validUserData(request.resource.data, uid);

      allow delete: if false;

      match /khatmas/{khatmaId} {
        allow read, write: if isOwner(uid);
      }

      match /activity/{docId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update, delete: if false;
      }
    }

    match /leaderboard/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid)
                            && validLeaderboardData(request.resource.data, uid);
      allow delete: if false;
    }

    match /khatmaRooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && validKhatmaRoomData(request.resource.data, roomId);

      allow update: if isSignedIn()
                    && validKhatmaRoomData(request.resource.data, roomId)
                    && (
                      resource.data.ownerUid == request.auth.uid
                      || exists(/databases/$(database)/documents/khatmaRooms/$(roomId)/members/$(request.auth.uid))
                    );

      allow delete: if false;

      match /members/{uid} {
        allow read: if isSignedIn();

        allow create: if isOwner(uid)
                      && validKhatmaRoomMemberData(request.resource.data, uid);

        allow update: if validKhatmaRoomMemberData(request.resource.data, uid)
                      && (
                        isOwner(uid)
                        || get(/databases/$(database)/documents/khatmaRooms/$(roomId)).data.ownerUid == request.auth.uid
                      );

        allow delete: if false;
      }
    }
    match /arenaQuestions/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /arenaAnswers/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}